<?xml version="1.0" encoding="utf-8" ?>
<configuration>

    <startup>
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
    </startup>

    <appSettings>
        <add key="OverTempThreshold" value="80"/>
        <add key="VoltageImbalancePct" value="10"/>
        <add key="PowerFlatlineWindow" value="5"/>
        <add key="AcCur1SpikeThreshold" value="50"/>
		<add key="DcVoltMin" value="400"/>
		<add key="DcVoltMax" value="900"/>
    </appSettings>

    <system.serviceModel>
        <services>
            <service name="Service.PvService">
                <host>
                    <baseAddresses>
                        <add baseAddress="net.tcp://localhost:4000"/>
                    </baseAddresses>
                </host>

                <endpoint
                    address="Service"
                    binding="netTcpBinding"
                    bindingConfiguration="tcpBinding"
                    contract="Common.IPvService"/>
            </service>
        </services>

        <bindings>
            <netTcpBinding>
                <binding name="tcpBinding"
                         transferMode="Streamed"
                         maxReceivedMessageSize="67108864"
                         sendTimeout="00:10:00"
                         receiveTimeout="00:10:00" />
            </netTcpBinding>
        </bindings>
    </system.serviceModel>

</configuration>